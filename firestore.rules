rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Simplify rules for testing: allow public read/write access to tasks, categories, and assignees
    match /tasks/{taskId} {
      allow read, write: if true;
    }

    match /categories/{categoryId} {
      allow read, write: if true;
    }

    match /assignees/{assigneeId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    // Default safety catch-all for any other pathways
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
